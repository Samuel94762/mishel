# Copia este archivo como .env y completa los valores
# NO subas el .env a GitHub

# MongoDB Atlas connection string
# Formato: mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/cita-app?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://TU_USUARIO:TU_PASSWORD@TU_CLUSTER.mongodb.net/cita-app?retryWrites=true&w=majority

# Puerto (Render lo asigna automáticamente, no tocar)
PORT=3000
